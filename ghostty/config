# =============================================
# Ghostty 终端配置文件
# 配置路径: ~/.config/ghostty/config
# 官方文档: https://ghostty.org/docs/config
# =============================================


# ===== 字体配置 =====

# 字体名称，使用 Nerd Font 以支持图标字符和 Powerline 符号
# default: 未设置（内置 JetBrains Mono 作为 fallback）
font-family = JetBrainsMono Nerd Font

# 字体大小，单位为 pt（磅）
# default: 13 (macOS), 12 (Linux)
font-size = 18

# 加粗渲染字体笔画，适合 macOS Retina 高分屏，避免字体过细
# default: false
font-thicken = true

# 调整单元格行高，百分比相对于默认行高，增加行距提升阅读舒适度
# default: 无调整
adjust-cell-height = 20%


# ===== 主题 =====

# 配色方案，运行 ghostty +list-themes 查看所有可用主题
# default: 无（使用内置默认配色）
theme = Catppuccin Mocha


# ===== 窗口外观 =====

# 背景不透明度，范围 0.0（全透明）~ 1.0（完全不透明）
# default: 1.0
background-opacity = 0.92

# 背景毛玻璃模糊半径，配合 background-opacity 呈现磨砂玻璃效果
# default: false（关闭）
background-blur-radius = 20

# 窗口内容区域左右内边距，单位为像素
# default: 2
window-padding-x = 8

# 窗口内容区域上下内边距，单位为像素
# default: 2
window-padding-y = 4

# macOS 标题栏样式：tabs（标签页合并）| native | transparent | hidden
# default: transparent
macos-titlebar-style = tabs

# 窗口状态持久化：always（总是恢复）| never | default（仅正常退出时保存）
# default: default
window-save-state = always


# ===== Shell 集成 =====

# Shell 集成功能，Ghostty 自动注入 shell 集成脚本
# cursor: 根据 shell 模式自动切换光标形状
# sudo: 在 sudo 命令中保持 shell 集成
# title: 将当前命令或目录设为终端标题
# default: cursor,title,path（sudo 默认关，path 默认开）
shell-integration-features = cursor,sudo,title


# ===== 鼠标 =====

# 打字时自动隐藏鼠标光标，移动鼠标后重新显示
# default: false
mouse-hide-while-typing = true

# 鼠标选中文本后自动复制到系统剪贴板：clipboard | none
# default: true（macOS 复制到选择缓冲区）
copy-on-select = clipboard


# ===== 剪贴板 =====

# 允许终端内程序通过 OSC 52 读取系统剪贴板：allow | deny | ask
# default: ask
clipboard-read = allow

# 粘贴保护：粘贴内容含换行符时是否弹出确认框，防止意外执行命令
# default: true
clipboard-paste-protection = false


# ===== 图像协议 =====

# 终端图像存储上限（字节），支持 Kitty 图像协议（yazi 预览等）
# default: 320000000（~305MB）
image-storage-limit = 320000000


# ===== 快捷键 =====
# 格式: keybind = 修饰键+按键=动作:参数
# 自定义快捷键是追加模式，不会覆盖内置默认快捷键
# super = Cmd (macOS) | alt = Option (macOS)

# --- 分屏操作（自定义，非默认快捷键）---
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down

# --- 分屏导航（自定义，非默认快捷键）---
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+alt+down=goto_split:bottom

# --- 以下为内置默认快捷键的显式声明 ---
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+0=reset_font_size
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5
